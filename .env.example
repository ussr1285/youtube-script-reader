# Input file with YouTube URLs (one per line)
URL_FILE=ycombinaotr-영상들.txt

# Preferred transcript languages (comma-separated, in priority order)
# First available language will be used
LANGUAGES=ko,en

# Delay between requests in seconds (rate limiting)
DELAY=3.0

# Cookie file for yt-dlp fallback (optional, helps bypass IP blocks)
# Export with: yt-dlp --cookies-from-browser chrome --cookies cookies.txt --skip-download "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
COOKIES_FILE=cookies.txt
